# This directory holds the Anthropic API key — files are NEVER committed to git.
#
# Option A — let the setup wizard do it (recommended):
#   docker compose up          # wizard dialog appears on first run
#
# Option B — write the key manually:
#   chmod 700 secrets/
#   echo "sk-ant-YOUR_KEY_HERE" > secrets/anthropic_api_key
#   chmod 600 secrets/anthropic_api_key
#
# The key file (anthropic_api_key) is excluded by .gitignore via secrets/*.
# Only this placeholder is tracked.
