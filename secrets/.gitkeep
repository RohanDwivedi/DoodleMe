# This directory is intentionally empty and kept only to preserve the folder in git.
#
# The API key does NOT live here.
# It lives at a system path, outside this repository:
#
#   /etc/doodleme/secrets/anthropic_api_key
#
# Option A — let the setup wizard create it automatically (recommended):
#   docker compose up          # wizard dialog appears on first run
#
# Option B — write it manually (requires root):
#   sudo mkdir -p  /etc/doodleme/secrets
#   sudo chmod 700 /etc/doodleme/secrets
#   sudo sh -c 'echo "sk-ant-YOUR_KEY_HERE" > /etc/doodleme/secrets/anthropic_api_key'
#   sudo chmod 600 /etc/doodleme/secrets/anthropic_api_key
#
# DO NOT put the key in .env, environment variables, or anywhere in this repo.
