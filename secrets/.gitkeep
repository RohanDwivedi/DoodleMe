# This directory holds Docker secrets — files are NEVER committed to git.
#
# Setup (one time):
#   chmod 700 secrets/
#   echo "sk-ant-YOUR_KEY_HERE" > secrets/anthropic_api_key.txt
#   chmod 600 secrets/anthropic_api_key.txt
#
# The actual key file (anthropic_api_key.txt) is excluded by .gitignore.
# Only this placeholder file is tracked.
