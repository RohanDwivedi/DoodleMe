# Copy this file to .env and fill in your values.
# docker compose will load .env automatically.
#
# API KEY — do NOT put it here. Ever.
# The key lives at /etc/doodleme/secrets/anthropic_api_key on the host.
# The setup wizard creates it automatically on first `docker compose up`.
# To set it manually (requires root):
#   sudo mkdir -p /etc/doodleme/secrets && sudo chmod 700 /etc/doodleme/secrets
#   sudo sh -c 'echo "sk-ant-…" > /etc/doodleme/secrets/anthropic_api_key'
#   sudo chmod 600 /etc/doodleme/secrets/anthropic_api_key

# X11 display — usually :0 on a local desktop.
# Your shell's $DISPLAY is used automatically if not set here.
# DISPLAY=:0

# ROS2 domain (0–232). Must match other nodes on your network.
# ROS_DOMAIN_ID=0
