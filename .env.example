# Copy this file to .env and fill in your values.
# docker compose will load .env automatically.
#
# API KEY — do NOT put it here.
# The setup wizard writes it automatically on first `docker compose up`.
# To set it manually instead:
#   echo "sk-ant-YOUR_KEY" > secrets/anthropic_api_key
#   chmod 600 secrets/anthropic_api_key
#
# As a last resort you can export ANTHROPIC_API_KEY in your shell,
# which the app will pick up at a lower priority than the secrets file.

# X11 display — usually :0 on a local desktop.
# Your shell's $DISPLAY is used automatically if not set here.
# DISPLAY=:0

# ROS2 domain (0–232). Must match other nodes on your network.
# ROS_DOMAIN_ID=0
