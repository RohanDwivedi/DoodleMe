# Copy this file to .env and fill in your values.
# docker compose will load .env automatically.

# Your Anthropic API key (console.anthropic.com → API Keys).
# Alternatively, enter it through the Settings dialog inside the app.
ANTHROPIC_API_KEY=sk-ant-...

# X11 display — usually :0 on a local desktop.
# Your shell's $DISPLAY is used automatically if not set here.
# DISPLAY=:0

# ROS2 domain (0–232). Must match other nodes on your network.
# ROS_DOMAIN_ID=0
